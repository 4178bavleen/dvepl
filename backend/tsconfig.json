{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",

    "rootDir": "./src",
    "outDir": "./dist",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,

    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noImplicitAny": false,

    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,

    "moduleDetection": "force",
    "allowUmdGlobalAccess": true
  },
  "include": ["src/**/*", "bin/**/*", "src/types/**/*.d.ts"],
  "exclude": ["node_modules", "dist"]
}
