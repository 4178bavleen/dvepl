generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id                      String                   @id @default(uuid())
  name                    String
  gst                     String?                  @unique
  pan                     String?                  @unique
  email                   String?
  phone                   String?
  address                 String?
  isActive                Boolean                  @default(true)
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  deletedAt               DateTime?
  stockTransfers          StockTransfer[]
  approvalRequests        ApprovalRequest[]
  approvalWorkflows       ApprovalWorkflow[]
  boms                    BOM[]
  boqs                    BOQ[]
  branches                Branch[]
  costCenters             CostCenter[]
  creditNotes             CreditNote[]
  customers               Customer[]
  dashboardWidgets        DashboardWidget[]
  debitNotes              DebitNote[]
  dispatches              Dispatch[]
  divisions               Division[]
  employees               Employee[]
  engineeringProjects     EngineeringProject[]
  expenses                Expense[]
  goodsReceipts           GoodsReceipt[]
  governmentDepartments   GovernmentDepartment[]
  inspectionChecklists    InspectionChecklist[]
  inspections             Inspection[]
  inventories             Inventory[]
  invoices                Invoice[]
  ledgerEntries           LedgerEntry[]
  materialBrands          MaterialBrand[]
  materialCategories      MaterialCategory[]
  materialSpecifications  MaterialSpecification[]
  materials               Material[]
  payments                Payment[]
  productionPlans         ProductionPlan[]
  purchaseOrders          PurchaseOrder[]
  purchaseRequests        PurchaseRequest[]
  quotations              Quotation[]
  referenceCodeCounters   ReferenceCodeCounter[]
  reportDefinitions       ReportDefinition[]
  reportSchedules         ReportSchedule[]
  roles                   Role[]
  salesOrders             SalesOrder[]
  sections                Section[]
  subDivisions            SubDivision[]
  technicalClarifications TechnicalClarification[]
  tenderRequests          TenderRequest[]
  tenders                 Tender[]
  users                   User[]
  vehicles                Vehicle[]
  vendors                 Vendor[]
  warehouses              Warehouse[]
  workOrders              WorkOrder[]

  @@map("companies")
}

model Branch {
  id          String       @id @default(uuid())
  companyId   String
  name        String
  code        String
  address     String?
  city        String?
  state       String?
  pincode     String?
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  deletedAt   DateTime?
  company     Company      @relation(fields: [companyId], references: [id])
  departments Department[]
  employees   Employee[]

  @@unique([companyId, code])
  @@map("branches")
}

model Department {
  id          String       @id @default(uuid())
  branchId    String
  name        String
  code        String
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  deletedAt   DateTime?
  costCenters CostCenter[]
  branch      Branch       @relation(fields: [branchId], references: [id])
  employees   Employee[]
  sections    Section[]
  teams       Team[]
  tenders     Tender[]

  @@unique([branchId, code])
  @@map("departments")
}

model Team {
  id           String     @id @default(uuid())
  departmentId String
  name         String
  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  deletedAt    DateTime?
  employees    Employee[]
  department   Department @relation(fields: [departmentId], references: [id])

  @@map("teams")
}

model Designation {
  id        String     @id @default(uuid())
  title     String     @unique
  level     Int?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  deletedAt DateTime?
  employees Employee[]

  @@map("designations")
}

model CostCenter {
  id           String      @id @default(uuid())
  companyId    String
  departmentId String?
  code         String
  name         String
  budget       Decimal?    @db.Decimal(15, 2)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  deletedAt    DateTime?
  company      Company     @relation(fields: [companyId], references: [id])
  department   Department? @relation(fields: [departmentId], references: [id])

  @@unique([companyId, code])
  @@map("cost_centers")
}

model User {
  id                                String                             @id @default(uuid())
  companyId                         String
  email                             String                             @unique
  phone                             String?                            @unique
  passwordHash                      String
  isEmailVerified                   Boolean                            @default(false)
  isPhoneVerified                   Boolean                            @default(false)
  isActive                          Boolean                            @default(true)
  createdAt                         DateTime                           @default(now())
  updatedAt                         DateTime                           @updatedAt
  deletedAt                         DateTime?
  name                              String
  orderAssignments                  SalesOrderAssignment[]
  approvedStockTransfers            StockTransfer[]                    @relation("StockTransferApprovedBy")
  completedStockTransfers           StockTransfer[]                    @relation("StockTransferCompletedBy")
  requestedStockTransfers           StockTransfer[]                    @relation("StockTransferRequestedBy")
  userPermissions                   UserPermission[]
  approvalHistories                 ApprovalHistory[]
  approvalRequestsAssigned          ApprovalRequest[]                  @relation("ApprovalRequestAssignedTo")
  approvalRequestsRequested         ApprovalRequest[]                  @relation("ApprovalRequestRequestedBy")
  auditLogs                         AuditLog[]
  bomrevisions                      BOMRevision[]
  approvedBOMs                      BOM[]                              @relation("BOMApprovedBy")
  createdBOMs                       BOM[]                              @relation("BOMCreatedBy")
  boqattachments                    BOQAttachment[]
  communicationLogs                 CommunicationHistory[]
  approvedCreditNotes               CreditNote[]                       @relation("CreditNoteApprovedBy")
  createdCreditNotes                CreditNote[]                       @relation("CreditNoteCreatedBy")
  dashboardWidgets                  DashboardWidget[]
  approvedDebitNotes                DebitNote[]                        @relation("DebitNoteApprovedBy")
  createdDebitNotes                 DebitNote[]                        @relation("DebitNoteCreatedBy")
  deliveryProofs                    DeliveryProof[]
  dispatches                        Dispatch[]
  approvedRevisions                 DrawingRevision[]                  @relation("RevisionApprovedBy")
  createdRevisions                  DrawingRevision[]                  @relation("RevisionCreatedBy")
  employee                          Employee?
  approvedDrawings                  EngineeringDrawing[]               @relation("DrawingApprovedBy")
  createdDrawings                   EngineeringDrawing[]               @relation("DrawingCreatedBy")
  engineeringProjectsApproved       EngineeringProject[]               @relation("EngineeringProjectApprovedBy")
  engineeringProjectsCreated        EngineeringProject[]               @relation("EngineeringProjectCreatedBy")
  approvedExpenses                  Expense[]                          @relation("ExpenseApprovedBy")
  createdExpenses                   Expense[]                          @relation("ExpenseCreatedBy")
  approvedGoodsReceipts             GoodsReceipt[]                     @relation("GoodsReceiptApprovedBy")
  receivedGoodsReceipts             GoodsReceipt[]                     @relation("GoodsReceiptReceivedBy")
  approvedInspections               Inspection[]                       @relation("InspectionApprovedBy")
  inspectedInspections              Inspection[]                       @relation("InspectionInspectedBy")
  inventoryTransactions             InventoryTransaction[]
  approvedInvoices                  Invoice[]                          @relation("InvoiceApprovedBy")
  createdInvoices                   Invoice[]                          @relation("InvoiceCreatedBy")
  ledgerEntries                     LedgerEntry[]
  materials                         Material[]
  otpRequests                       OtpRequest[]
  passwordResets                    PasswordReset[]
  payments                          Payment[]
  productionLogs                    ProductionLog[]
  approvedProductionPlans           ProductionPlan[]                   @relation("ProductionPlanApprovedBy")
  createdProductionPlans            ProductionPlan[]                   @relation("ProductionPlanCreatedBy")
  approvedPurchaseOrders            PurchaseOrder[]                    @relation("PurchaseOrderApprovedBy")
  createdPurchaseOrders             PurchaseOrder[]                    @relation("PurchaseOrderCreatedBy")
  approvedPurchaseRequests          PurchaseRequest[]                  @relation("PurchaseRequestApprovedBy")
  requestedPurchaseRequests         PurchaseRequest[]                  @relation("PurchaseRequestRequestedBy")
  quotationAttachments              QuotationAttachment[]
  quotationRevisions                QuotationRevision[]
  quotationsApproved                Quotation[]                        @relation("QuotationApprovedBy")
  quotationsCreated                 Quotation[]                        @relation("QuotationCreatedBy")
  refreshTokens                     RefreshToken[]
  reportDefinitions                 ReportDefinition[]
  reportSchedules                   ReportSchedule[]
  reworks                           Rework[]
  salesOrderAttachments             SalesOrderAttachment[]
  salesOrdersCreated                SalesOrder[]                       @relation("OrderCreatedBy")
  salesOrdersTaken                  SalesOrder[]                       @relation("OrderTakenBy")
  technicalClarificationActivities  TechnicalClarificationActivity[]
  technicalClarificationAttachments TechnicalClarificationAttachment[]
  technicalClarificationReplies     TechnicalClarificationReply[]
  technicalClarificationsAssigned   TechnicalClarification[]           @relation("TechnicalClarificationAssignedTo")
  technicalClarificationsRaised     TechnicalClarification[]           @relation("TechnicalClarificationRaisedBy")
  tenderRemarks                     TenderRemark[]
  tenderRequestsAssigned            TenderRequest[]                    @relation("TenderRequestAssignedTo")
  tendersAssigned                   Tender[]                           @relation("TenderAssignedTo")
  tendersCreated                    Tender[]                           @relation("TenderCreatedBy")
  userRoles                         UserRole[]
  sessions                          UserSession[]
  company                           Company                            @relation(fields: [companyId], references: [id])
  vendorRevisions                   VendorRevision[]                   @relation("VendorRevisionCreatedBy")
  vendorsCreated                    Vendor[]                           @relation("VendorCreatedBy")
  approvedWorkOrders                WorkOrder[]                        @relation("WorkOrderApprovedBy")
  assignedWorkOrders                WorkOrder[]                        @relation("WorkOrderAssignedTo")
  createdWorkOrders                 WorkOrder[]                        @relation("WorkOrderCreatedBy")

  @@index([companyId])
  @@map("users")
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  ipAddress String
  userAgent String?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("refresh_tokens")
}

model UserSession {
  id          String    @id @default(uuid())
  userId      String
  deviceId    String?
  deviceName  String?
  ipAddress   String?
  userAgent   String?
  loggedOutAt DateTime?
  lastSeenAt  DateTime  @default(now())
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("user_sessions")
}

model OtpRequest {
  id         String     @id @default(uuid())
  userId     String
  otpHash    String
  purpose    OtpPurpose
  expiresAt  DateTime
  consumedAt DateTime?
  attempts   Int        @default(0)
  createdAt  DateTime   @default(now())
  user       User       @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("otp_requests")
}

model PasswordReset {
  id                 String    @id @default(uuid())
  userId             String
  tokenHash          String    @unique
  expiresAt          DateTime
  usedAt             DateTime?
  requestedIp        String?
  requestedUserAgent String?
  createdAt          DateTime  @default(now())
  user               User      @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("password_resets")
}

model Role {
  id              String           @id @default(uuid())
  companyId       String
  name            String
  description     String?
  isSystem        Boolean          @default(false)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  deletedAt       DateTime?
  approvalLevels  ApprovalLevel[]
  rolePermissions RolePermission[]
  company         Company          @relation(fields: [companyId], references: [id])
  userRoles       UserRole[]

  @@unique([companyId, name])
  @@map("roles")
}

model PermissionGroup {
  id          String       @id @default(uuid())
  name        String       @unique
  description String?
  permissions Permission[]

  @@map("permission_groups")
}

model Permission {
  id              String           @id @default(uuid())
  groupId         String?
  code            String           @unique
  description     String?
  userPermissions UserPermission[]
  group           PermissionGroup? @relation(fields: [groupId], references: [id])
  rolePermissions RolePermission[]

  @@map("permissions")
}

model RolePermission {
  id           String     @id @default(uuid())
  roleId       String
  permissionId String
  createdAt    DateTime   @default(now())
  permission   Permission @relation(fields: [permissionId], references: [id])
  role         Role       @relation(fields: [roleId], references: [id])

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model UserRole {
  id        String   @id @default(uuid())
  userId    String
  roleId    String
  createdAt DateTime @default(now())
  role      Role     @relation(fields: [roleId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, roleId])
  @@map("user_roles")
}

model UserPermission {
  id           String     @id @default(uuid())
  userId       String
  permissionId String
  allowed      Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  permission   Permission @relation(fields: [permissionId], references: [id])
  user         User       @relation(fields: [userId], references: [id])

  @@unique([userId, permissionId])
}

model Employee {
  id                    String                     @id @default(uuid())
  userId                String?                    @unique
  companyId             String
  branchId              String?
  departmentId          String?
  teamId                String?
  designationId         String?
  reportsToId           String?
  employeeCode          String                     @unique
  firstName             String
  lastName              String
  dateOfBirth           DateTime?
  gender                String?
  dateOfJoining         DateTime?
  dateOfExit            DateTime?
  status                EmployeeStatus             @default(ACTIVE)
  createdAt             DateTime                   @default(now())
  updatedAt             DateTime                   @updatedAt
  deletedAt             DateTime?
  salesOrderAssignments SalesOrderAssignment[]
  attendances           Attendance[]
  contacts              EmployeeContact[]
  documents             EmployeeDocument[]
  education             EmployeeEducation[]
  emergencyContacts     EmployeeEmergencyContact[]
  experience            EmployeeExperience[]
  shiftAssignments      EmployeeShift[]
  branch                Branch?                    @relation(fields: [branchId], references: [id])
  company               Company                    @relation(fields: [companyId], references: [id])
  department            Department?                @relation(fields: [departmentId], references: [id])
  designation           Designation?               @relation(fields: [designationId], references: [id])
  reportsTo             Employee?                  @relation("EmployeeHierarchy", fields: [reportsToId], references: [id])
  subordinates          Employee[]                 @relation("EmployeeHierarchy")
  team                  Team?                      @relation(fields: [teamId], references: [id])
  user                  User?                      @relation(fields: [userId], references: [id])
  leaves                Leave[]
  salaries              Salary[]
  tenderRequestsCreated TenderRequest[]            @relation("TenderRequestCreatedBy")

  @@index([companyId])
  @@map("employees")
}

model EmployeeContact {
  id         String      @id @default(uuid())
  employeeId String
  type       ContactType
  value      String
  isPrimary  Boolean     @default(false)
  createdAt  DateTime    @default(now())
  employee   Employee    @relation(fields: [employeeId], references: [id])

  @@map("employee_contacts")
}

model EmployeeEmergencyContact {
  id           String   @id @default(uuid())
  employeeId   String
  name         String
  relationship String
  phone        String
  createdAt    DateTime @default(now())
  employee     Employee @relation(fields: [employeeId], references: [id])

  @@map("employee_emergency_contacts")
}

model EmployeeEducation {
  id            String   @id @default(uuid())
  employeeId    String
  degree        String
  institution   String
  yearOfPassing Int?
  grade         String?
  createdAt     DateTime @default(now())
  employee      Employee @relation(fields: [employeeId], references: [id])

  @@map("employee_education")
}

model EmployeeExperience {
  id          String    @id @default(uuid())
  employeeId  String
  companyName String
  designation String
  fromDate    DateTime?
  toDate      DateTime?
  createdAt   DateTime  @default(now())
  employee    Employee  @relation(fields: [employeeId], references: [id])

  @@map("employee_experience")
}

model EmployeeDocument {
  id           String   @id @default(uuid())
  employeeId   String
  documentType String
  fileUrl      String
  fileName     String
  createdAt    DateTime @default(now())
  employee     Employee @relation(fields: [employeeId], references: [id])

  @@map("employee_documents")
}

model Shift {
  id          String          @id @default(uuid())
  name        String          @unique
  startTime   String
  endTime     String
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  deletedAt   DateTime?
  assignments EmployeeShift[]

  @@map("shifts")
}

model EmployeeShift {
  id            String    @id @default(uuid())
  employeeId    String
  shiftId       String
  effectiveFrom DateTime
  effectiveTo   DateTime?
  employee      Employee  @relation(fields: [employeeId], references: [id])
  shift         Shift     @relation(fields: [shiftId], references: [id])

  @@map("employee_shifts")
}

model Holiday {
  id   String   @id @default(uuid())
  name String   @unique
  date DateTime
  type String?

  @@map("holidays")
}

model Attendance {
  id         String           @id @default(uuid())
  employeeId String
  date       DateTime
  checkIn    DateTime?
  checkOut   DateTime?
  status     AttendanceStatus @default(PRESENT)
  remarks    String?
  createdAt  DateTime         @default(now())
  employee   Employee         @relation(fields: [employeeId], references: [id])

  @@unique([employeeId, date])
  @@index([employeeId])
  @@map("attendance")
}

model Leave {
  id           String      @id @default(uuid())
  employeeId   String
  leaveType    String
  fromDate     DateTime
  toDate       DateTime
  reason       String?
  status       LeaveStatus @default(PENDING)
  approvedById String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  employee     Employee    @relation(fields: [employeeId], references: [id])

  @@index([employeeId])
  @@map("leaves")
}

model Salary {
  id            String   @id @default(uuid())
  employeeId    String
  effectiveFrom DateTime
  basic         Decimal  @db.Decimal(12, 2)
  hra           Decimal  @default(0) @db.Decimal(12, 2)
  allowances    Decimal  @default(0) @db.Decimal(12, 2)
  deductions    Decimal  @default(0) @db.Decimal(12, 2)
  ctc           Decimal  @db.Decimal(12, 2)
  createdAt     DateTime @default(now())
  employee      Employee @relation(fields: [employeeId], references: [id])

  @@index([employeeId])
  @@map("salaries")
}

model Customer {
  id                String                 @id @default(uuid())
  companyId         String
  name              String
  gst               String?
  pan               String?
  billingAddress    String?
  shippingAddress   String?
  paymentTerms      String?
  isGovernment      Boolean                @default(false)
  isActive          Boolean                @default(true)
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  deletedAt         DateTime?
  firmName          String?
  communicationLogs CommunicationHistory[]
  contacts          ContactPerson[]
  company           Company                @relation(fields: [companyId], references: [id])
  invoices          Invoice[]
  vendorInvoices    Invoice[]              @relation("VendorInvoices")
  purchaseOrders    PurchaseOrder[]
  quotations        Quotation[]
  salesOrders       SalesOrder[]
  tenderRequests    TenderRequest[]
  tenders           Tender[]

  @@index([companyId])
  @@map("customers")
}

model ContactPerson {
  id          String    @id @default(uuid())
  customerId  String
  name        String
  designation String?
  phone       String?
  email       String?
  isPrimary   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  customer    Customer  @relation(fields: [customerId], references: [id])

  @@map("contact_persons")
}

model CommunicationHistory {
  id         String            @id @default(uuid())
  customerId String
  userId     String?
  type       CommunicationType
  subject    String?
  content    String?
  createdAt  DateTime          @default(now())
  customer   Customer          @relation(fields: [customerId], references: [id])
  user       User?             @relation(fields: [userId], references: [id])

  @@index([customerId])
  @@map("communication_history")
}

model Tender {
  id                      String                   @id @default(uuid())
  companyId               String
  tenderRequestId         String?
  customerId              String?
  departmentId            String?
  sectionId               String?
  divisionId              String?
  subDivisionId           String?
  tenderNo                String?
  tenderCode              String?                  @unique
  title                   String
  description             String?
  projectLocation         String?
  estimatedCost           Decimal?                 @db.Decimal(15, 2)
  publishedAt             DateTime?
  dueDate                 DateTime?
  status                  TenderStatus             @default(DRAFT)
  createdById             String
  assignedToId            String?
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  deletedAt               DateTime?
  governmentDepartmentId  String?
  boqs                    BOQ[]
  quotations              Quotation[]
  referenceCodes          ReferenceCode[]
  salesOrders             SalesOrder[]
  technicalClarifications TechnicalClarification[]
  activities              TenderActivity[]
  files                   TenderFile[]
  remarks                 TenderRemark[]
  assignedTo              User?                    @relation("TenderAssignedTo", fields: [assignedToId], references: [id])
  company                 Company                  @relation(fields: [companyId], references: [id])
  createdBy               User                     @relation("TenderCreatedBy", fields: [createdById], references: [id])
  customer                Customer?                @relation(fields: [customerId], references: [id])
  department              Department?              @relation(fields: [departmentId], references: [id])
  division                Division?                @relation(fields: [divisionId], references: [id])
  governmentDepartment    GovernmentDepartment?    @relation(fields: [governmentDepartmentId], references: [id])
  section                 Section?                 @relation(fields: [sectionId], references: [id])
  subDivision             SubDivision?             @relation(fields: [subDivisionId], references: [id])
  tenderRequest           TenderRequest?           @relation(fields: [tenderRequestId], references: [id])

  @@index([companyId])
  @@index([status])
  @@index([dueDate])
  @@map("tenders")
}

model TenderFile {
  id         String   @id @default(uuid())
  tenderId   String
  fileName   String
  fileUrl    String
  fileType   String?
  uploadedBy String?
  createdAt  DateTime @default(now())
  tender     Tender   @relation(fields: [tenderId], references: [id])

  @@map("tender_files")
}

model TenderRemark {
  id        String   @id @default(uuid())
  tenderId  String
  userId    String?
  remark    String
  createdAt DateTime @default(now())
  tender    Tender   @relation(fields: [tenderId], references: [id])
  user      User?    @relation(fields: [userId], references: [id])

  @@map("tender_remarks")
}

model TenderRequest {
  id             String              @id @default(uuid())
  companyId      String
  customerId     String?
  assignedToId   String?
  createdById    String?
  source         TenderRequestSource @default(WEBSITE)
  status         TenderRequestStatus @default(NEW)
  title          String
  description    String?
  estimatedValue Decimal?            @db.Decimal(15, 2)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  deletedAt      DateTime?
  assignedTo     User?               @relation("TenderRequestAssignedTo", fields: [assignedToId], references: [id])
  company        Company             @relation(fields: [companyId], references: [id])
  createdBy      Employee?           @relation("TenderRequestCreatedBy", fields: [createdById], references: [id])
  customer       Customer?           @relation(fields: [customerId], references: [id])
  tenders        Tender[]

  @@index([companyId])
  @@index([assignedToId])
  @@map("tender_requests")
}

model TenderActivity {
  id          String   @id @default(uuid())
  tenderId    String
  action      String
  oldValue    Json?
  newValue    Json?
  performedBy String?
  createdAt   DateTime @default(now())
  tender      Tender   @relation(fields: [tenderId], references: [id])

  @@map("tender_activities")
}

model GovernmentDepartment {
  id        String    @id @default(uuid())
  companyId String
  name      String
  code      String?
  shortName String?
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  company   Company   @relation(fields: [companyId], references: [id])
  sections  Section[]
  tenders   Tender[]

  @@unique([companyId, name])
  @@map("government_departments")
}

model Section {
  id                     String                @id @default(uuid())
  companyId              String
  departmentId           String
  name                   String
  code                   String?
  isActive               Boolean               @default(true)
  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @updatedAt
  deletedAt              DateTime?
  governmentDepartmentId String?
  divisions              Division[]
  company                Company               @relation(fields: [companyId], references: [id])
  department             Department            @relation(fields: [departmentId], references: [id])
  governmentDepartment   GovernmentDepartment? @relation(fields: [governmentDepartmentId], references: [id])
  tenders                Tender[]

  @@unique([departmentId, name])
  @@map("sections")
}

model Division {
  id           String        @id @default(uuid())
  companyId    String
  sectionId    String
  name         String
  code         String?
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  deletedAt    DateTime?
  company      Company       @relation(fields: [companyId], references: [id])
  section      Section       @relation(fields: [sectionId], references: [id])
  subDivisions SubDivision[]
  tenders      Tender[]

  @@unique([sectionId, name])
  @@map("divisions")
}

model SubDivision {
  id         String    @id @default(uuid())
  companyId  String
  divisionId String
  name       String
  code       String?
