  referenceId   String?
  createdById   String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?
  company       Company   @relation(fields: [companyId], references: [id])
  createdBy     User      @relation(fields: [createdById], references: [id])
  expense       Expense?  @relation(fields: [referenceId], references: [id], map: "ledger_entries_expense_referenceId_fkey")
  invoice       Invoice?  @relation(fields: [referenceId], references: [id], map: "ledger_entries_invoice_referenceId_fkey")

  @@index([companyId])
  @@index([account])
  @@index([entryDate])
  @@map("ledger_entries")
}

model ReportDefinition {
  id           String            @id @default(uuid())
  companyId    String
  name         String
  description  String?
  reportType   String
  query        String
  parameters   Json?
  outputFormat String
  isSystem     Boolean           @default(false)
  isActive     Boolean           @default(true)
  createdById  String
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  deletedAt    DateTime?
  widgets      DashboardWidget[]
  company      Company           @relation(fields: [companyId], references: [id])
  createdBy    User              @relation(fields: [createdById], references: [id])
  schedules    ReportSchedule[]

  @@unique([companyId, name])
  @@index([companyId])
  @@map("report_definitions")
}

model ReportSchedule {
  id          String            @id @default(uuid())
  companyId   String
  reportId    String
  name        String
  frequency   ScheduleFrequency
  dayOfWeek   Int?
  dayOfMonth  Int?
  time        String
  recipients  String[]
  formats     String[]
  isActive    Boolean           @default(true)
  lastRunAt   DateTime?
  nextRunAt   DateTime?
  createdById String
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  deletedAt   DateTime?
  company     Company           @relation(fields: [companyId], references: [id])
  createdBy   User              @relation(fields: [createdById], references: [id])
  report      ReportDefinition  @relation(fields: [reportId], references: [id])

  @@index([companyId])
  @@index([reportId])
  @@map("report_schedules")
}

model DashboardWidget {
  id            String           @id @default(uuid())
  companyId     String
  reportId      String
  name          String
  widgetType    String
  configuration Json
  position      Int
  isActive      Boolean          @default(true)
  createdById   String
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  deletedAt     DateTime?
  company       Company          @relation(fields: [companyId], references: [id])
  createdBy     User             @relation(fields: [createdById], references: [id])
  report        ReportDefinition @relation(fields: [reportId], references: [id])

  @@index([companyId])
  @@map("dashboard_widgets")
}

model Vendor {
  id String @id @default(uuid())

  companyId String

  name String

  category String?

  contactPerson String?

  phone String?

  email String?

  gstNumber String?

  address String?

  notes String?

  revisionCount Int @default(0)

  createdById String

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  deletedAt DateTime?

  revisions VendorRevision[]

  materials Material[] // <-- ADD THIS

  company Company @relation(fields: [companyId], references: [id])

  createdBy User @relation("VendorCreatedBy", fields: [createdById], references: [id])

  @@index([companyId])
  @@index([name])
  @@index([category])
  @@map("vendors")
}

model VendorRevision {
  id          String   @id @default(uuid())
  vendorId    String
  action      String
  oldData     Json?
  newData     Json?
  createdById String
  createdAt   DateTime @default(now())
  createdBy   User     @relation("VendorRevisionCreatedBy", fields: [createdById], references: [id])
  vendor      Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@index([vendorId])
  @@map("vendor_revisions")
}

