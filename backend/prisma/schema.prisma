model SalesOrder {
  id String @id @default(uuid())

  companyId String

  // Assignment
  dveplCode String           @unique
  status    SalesOrderStatus @default(PENDING)

  orderTakenById String?
  assignedToId   String?

  // Order Information
  partyName           String
  caNo                String?
  contactDetails      String?
  orderConfirmDate    DateTime?
  deliveryMonthTarget String?
  poDate              DateTime?

  // Drawing
  drawingConcernedPerson String?
  drawingApprovedDate    DateTime?
  drawingStatus          DrawingStatus?
  drawingRemarks         String?

  // Totals
  subtotal   Decimal @default(0) @db.Decimal(15, 2)
  gstTotal   Decimal @default(0) @db.Decimal(15, 2)
  grandTotal Decimal @default(0) @db.Decimal(15, 2)

  // Additional
  inspectionField  String?
  sendNotification Boolean @default(true)

  remarks String?

  createdById String

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  company Company @relation(fields: [companyId], references: [id])

  orderTakenBy User?                  @relation("OrderTakenBy", fields: [orderTakenById], references: [id])
  assignments  SalesOrderAssignment[]

  createdBy User @relation("OrderCreatedBy", fields: [createdById], references: [id])

  items SalesOrderItem[]
  // concernedPersons  SalesOrderConcernedPerson[]

  customer              Customer?              @relation(fields: [customerId], references: [id])
  customerId            String?
  tender                Tender?                @relation(fields: [tenderId], references: [id])
  tenderId              String?
  quotation             Quotation?             @relation(fields: [quotationId], references: [id])
  quotationId           String?
  salesOrderAttachments SalesOrderAttachment[]
  engineeringProjects   EngineeringProject[]
  workOrders            WorkOrder[]
  dispatches            Dispatch[]
  invoices              Invoice[]

  @@index([companyId])
  @@index([status])
  @@index([orderTakenById])
  @@map("sales_orders")
}

enum SalesOrderStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  ON_HOLD
}

model SalesOrderAssignment {
  id String @id @default(uuid())

  salesOrderId String

  userId String

  assignedAt DateTime @default(now())

  salesOrder SalesOrder @relation(fields: [salesOrderId], references: [id], onDelete: Cascade)

  user User @relation(fields: [userId], references: [id])

  @@unique([salesOrderId, userId])
  @@index([userId])
  @@map("sales_order_assignments")
}

// enum SalesOrderStatus {
//   DRAFT
//   CONFIRMED
//   IN_PRODUCTION
//   READY
//   DISPATCHED
//   COMPLETED
//   CANCELLED
// }

model SalesOrderItem {
  id String @id @default(uuid())

  salesOrderId String

  itemCode String

  description String

  unit String?

  quantity Decimal @db.Decimal(15, 3)

  unitPrice Decimal @db.Decimal(15, 2)

  gstPercentage Decimal @db.Decimal(5, 2)

  totalPrice Decimal @db.Decimal(15, 2)

  remarks String?

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  deletedAt     DateTime?
  dispatchItems DispatchItem[]
  salesOrder    SalesOrder     @relation(fields: [salesOrderId], references: [id])

  @@map("sales_order_items")
}

model SalesOrderAttachment {
  id           String   @id @default(uuid())
  salesOrderId String
  fileName     String
  fileUrl      String
  fileSize     Int?
  mimeType     String?
  uploadedById String
  createdAt    DateTime @default(now())

  salesOrder SalesOrder @relation(fields: [salesOrderId], references: [id])
  uploadedBy User       @relation(fields: [uploadedById], references: [id])

  @@index([salesOrderId])
  @@map("sales_order_attachments")
}

// ============================================================
// 6. ENGINEERING MODULE
// ============================================================

model EngineeringProject {
  id           String            @id @default(uuid())
  companyId    String
  salesOrderId String?
  name         String
  description  String?
  status       EngineeringStatus @default(DRAFT)
  approvedById String?
  approvedAt   DateTime?
  createdById  String
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  deletedAt    DateTime?

  company    Company     @relation(fields: [companyId], references: [id])
  salesOrder SalesOrder? @relation(fields: [salesOrderId], references: [id])

  approvedBy User? @relation("EngineeringProjectApprovedBy", fields: [approvedById], references: [id])
  createdBy  User  @relation("EngineeringProjectCreatedBy", fields: [createdById], references: [id])

  drawings EngineeringDrawing[]
  boms     BOM[]

  @@index([companyId])
  @@map("engineering_projects")
}

enum EngineeringStatus {
  DRAFT
  IN_PROGRESS
  REVIEW
  APPROVED
  RELEASED
  REJECTED
  CANCELLED
}

model EngineeringDrawing {
  id           String        @id @default(uuid())
  projectId    String
  drawingNo    String        @unique
  title        String
  description  String?
  drawingType  DrawingType
  fileUrl      String
  fileName     String
  fileSize     Int?
  mimeType     String?
  status       DrawingStatus @default(PENDING)
  approvedById String?
  approvedAt   DateTime?
  createdById  String
  version      Int           @default(1)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  deletedAt    DateTime?

  project EngineeringProject @relation(fields: [projectId], references: [id])

  approvedBy User? @relation("DrawingApprovedBy", fields: [approvedById], references: [id])
  createdBy  User  @relation("DrawingCreatedBy", fields: [createdById], references: [id])

  revisions DrawingRevision[]

  @@index([projectId])
  @@index([drawingType])
  @@map("engineering_drawings")
}

enum DrawingType {
  SLD
  GA_DRAWING
  WIRING_DIAGRAM
  LAYOUT
  CAD
  PDF
}

enum DrawingStatus {
  DRAFT
  IN_REVIEW
  APPROVED
  REJECTED
  OBSOLETE
  PENDING
}

model DrawingRevision {
  id           String    @id @default(uuid())
  drawingId    String
  revisionNo   Int
  fileUrl      String
  fileName     String
  changes      String?
  approvedById String?
  approvedAt   DateTime?
  createdById  String
  createdAt    DateTime  @default(now())

  drawing     EngineeringDrawing @relation(fields: [drawingId], references: [id])
  aapprovedBy User?              @relation("RevisionApprovedBy", fields: [approvedById], references: [id])
  createdBy   User               @relation("RevisionCreatedBy", fields: [createdById], references: [id])

  @@unique([drawingId, revisionNo])
  @@index([drawingId])
  @@map("drawing_revisions")
}

// ============================================================
// 7. BILL OF MATERIALS (BOM) MODULE
// ============================================================

model BOM {
  id           String    @id @default(uuid())
  companyId    String
  projectId    String
  name         String
  description  String?
  version      Int       @default(1)
  isActive     Boolean   @default(true)
  approvedById String?
  approvedAt   DateTime?
  createdById  String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  company    Company            @relation(fields: [companyId], references: [id])
  project    EngineeringProject @relation(fields: [projectId], references: [id])
  approvedBy User?              @relation("BOMApprovedBy", fields: [approvedById], references: [id])
  createdBy  User               @relation("BOMCreatedBy", fields: [createdById], references: [id])

  assemblies BOMAssembly[]
  revisions  BOMRevision[]

  @@unique([projectId, version])
  @@index([companyId])
  @@map("boms")
}

model BOMAssembly {
  id              String    @id @default(uuid())
  bomId           String
  parentId        String?
  name            String
  description     String?
  quantity        Decimal   @db.Decimal(15, 3)
  wastePercentage Decimal   @default(0) @db.Decimal(5, 2)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  bom      BOM           @relation(fields: [bomId], references: [id])
  parent   BOMAssembly?  @relation("BOMAssemblyHierarchy", fields: [parentId], references: [id])
  children BOMAssembly[] @relation("BOMAssemblyHierarchy")

  items BOMItem[]

  @@index([bomId])
  @@index([parentId])
  @@map("bom_assemblies")
}

model BOMItem {
  id              String    @id @default(uuid())
  assemblyId      String
  materialId      String
  quantity        Decimal   @db.Decimal(15, 3)
  wastePercentage Decimal   @default(0) @db.Decimal(5, 2)
  remarks         String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  assembly BOMAssembly @relation(fields: [assemblyId], references: [id])
  material Material    @relation(fields: [materialId], references: [id])

  @@index([assemblyId])
  @@index([materialId])
  @@map("bom_items")
}

model BOMRevision {
  id          String   @id @default(uuid())
  bomId       String
  revisionNo  Int
  changes     Json?
  reason      String?
  revisedById String
  createdAt   DateTime @default(now())

  bom       BOM  @relation(fields: [bomId], references: [id])
  revisedBy User @relation(fields: [revisedById], references: [id])

  @@unique([bomId, revisionNo])
  @@index([bomId])
  @@map("bom_revisions")
}

// ============================================================
// 8. MATERIAL MASTER MODULE
// ============================================================

model Material {
  id                    String    @id @default(uuid())
  companyId             String
  categoryId            String?
  brandId               String?
  specificationId       String?
  materialCode          String    @unique
  name                  String
  description           String?
  hsnCode               String?
  gst                   Decimal   @db.Decimal(5, 2)
  unit                  String
  weight                Decimal?  @db.Decimal(10, 3)
  color                 String?
  alternativeMaterialId String?
  preferredVendorId     String?
  isActive              Boolean   @default(true)
  createdById           String
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  deletedAt             DateTime?

  company       Company                @relation(fields: [companyId], references: [id])
  category      MaterialCategory?      @relation(fields: [categoryId], references: [id])
  brand         MaterialBrand?         @relation(fields: [brandId], references: [id])
  specification MaterialSpecification? @relation(fields: [specificationId], references: [id])
  alternative   Material?              @relation("MaterialAlternative", fields: [alternativeMaterialId], references: [id])
  alternatives  Material[]             @relation("MaterialAlternative")
  createdBy     User                   @relation(fields: [createdById], references: [id])

  inventories          Inventory[]
  purchaseOrderItems   PurchaseOrderItem[]
  goodsReceiptItems    GoodsReceiptItem[]
  bomItems             BOMItem[]
  purchaseRequestItems PurchaseRequestItem[]
  stockTransfers       StockTransfer[]
  workOrders           WorkOrder[]
  workOrderItems       WorkOrderItem[]
  inspections          Inspection[]

  @@index([companyId])
  @@index([materialCode])
  @@index([categoryId])
  @@map("materials")
}

model MaterialCategory {
  id          String    @id @default(uuid())
  companyId   String
  parentId    String?
  name        String
  code        String
  description String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  company  Company            @relation(fields: [companyId], references: [id])
  parent   MaterialCategory?  @relation("MaterialCategoryHierarchy", fields: [parentId], references: [id])
  children MaterialCategory[] @relation("MaterialCategoryHierarchy")

  materials Material[]

  @@unique([companyId, code])
  @@index([companyId])
  @@map("material_categories")
}

model MaterialBrand {
  id          String    @id @default(uuid())
  companyId   String
  name        String
  code        String
  description String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  company Company @relation(fields: [companyId], references: [id])

  materials Material[]

  @@unique([companyId, code])
  @@map("material_brands")
}

model MaterialSpecification {
  id          String    @id @default(uuid())
  companyId   String
  name        String
  value       String
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  company Company @relation(fields: [companyId], references: [id])

  materials Material[]

  @@map("material_specifications")
}

// ============================================================
// 9. PURCHASE MODULE
// ============================================================

model PurchaseRequest {
  id            String                @id @default(uuid())
  companyId     String
  requestNo     String                @unique
  title         String
  description   String?
  priority      Priority              @default(MEDIUM)
  status        PurchaseRequestStatus @default(DRAFT)
  requestedById String
  approvedById  String?
  approvedAt    DateTime?
  requiredBy    DateTime?
  remarks       String?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  deletedAt     DateTime?

  company Company @relation(fields: [companyId], references: [id])

  requestedBy User  @relation("PurchaseRequestRequestedBy", fields: [requestedById], references: [id])
  approvedBy  User? @relation("PurchaseRequestApprovedBy", fields: [approvedById], references: [id])

  items  PurchaseRequestItem[]
  orders PurchaseOrder[]

  @@index([companyId])
  @@index([status])
  @@map("purchase_requests")
}

enum PurchaseRequestStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  PO_CREATED
  CANCELLED
}

model PurchaseRequestItem {
  id             String    @id @default(uuid())
  requestId      String
  materialId     String
  quantity       Decimal   @db.Decimal(15, 3)
  unit           String
  estimatedPrice Decimal   @db.Decimal(15, 2)
  remarks        String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  request  PurchaseRequest @relation(fields: [requestId], references: [id])
  material Material        @relation(fields: [materialId], references: [id])

  @@index([requestId])
  @@map("purchase_request_items")
}

model PurchaseOrder {
  id               String              @id @default(uuid())
  companyId        String
  poNo             String              @unique
  requestId        String?
  vendorId         String
  orderDate        DateTime            @default(now())
  expectedDelivery DateTime?
  status           PurchaseOrderStatus @default(DRAFT)
  paymentTerms     String?
  shippingTerms    String?
  currency         String              @default("INR")
  subtotal         Decimal             @db.Decimal(15, 2)
  tax              Decimal             @db.Decimal(15, 2)
  total            Decimal             @db.Decimal(15, 2)
  createdById      String
  approvedById     String?
  approvedAt       DateTime?
  sentAt           DateTime?
  remarks          String?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  deletedAt        DateTime?

  company Company          @relation(fields: [companyId], references: [id])
  request PurchaseRequest? @relation(fields: [requestId], references: [id])
  vendor  Customer         @relation(fields: [vendorId], references: [id])

  createdBy  User  @relation("PurchaseOrderCreatedBy", fields: [createdById], references: [id])
  approvedBy User? @relation("PurchaseOrderApprovedBy", fields: [approvedById], references: [id])

  items         PurchaseOrderItem[]
  goodsReceipts GoodsReceipt[]
  invoices      Invoice[]

  @@index([companyId])
  @@index([status])
  @@index([poNo])
  @@map("purchase_orders")
}

enum PurchaseOrderStatus {
  DRAFT
  APPROVED
  SENT
  PARTIAL_RECEIVED
  COMPLETED
  CANCELLED
}

model PurchaseOrderItem {
  id          String    @id @default(uuid())
  poId        String
  materialId  String
  quantity    Decimal   @db.Decimal(15, 3)
  unitPrice   Decimal   @db.Decimal(15, 2)
  totalPrice  Decimal   @db.Decimal(15, 2)
  receivedQty Decimal   @default(0) @db.Decimal(15, 3)
  remarks     String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  po       PurchaseOrder @relation(fields: [poId], references: [id])
  material Material      @relation(fields: [materialId], references: [id])

  goodsReceiptItems GoodsReceiptItem[]

  @@index([poId])
  @@map("purchase_order_items")
}

model GoodsReceipt {
  id           String             @id @default(uuid())
  companyId    String
  poId         String
  grnNo        String             @unique
  receiptDate  DateTime           @default(now())
  status       GoodsReceiptStatus @default(DRAFT)
  invoiceNo    String?
  invoiceDate  DateTime?
  receivedById String
  approvedById String?
  approvedAt   DateTime?
  remarks      String?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  deletedAt    DateTime?

  company Company       @relation(fields: [companyId], references: [id])
  po      PurchaseOrder @relation(fields: [poId], references: [id])

  receivedBy User  @relation("GoodsReceiptReceivedBy", fields: [receivedById], references: [id])
  approvedBy User? @relation("GoodsReceiptApprovedBy", fields: [approvedById], references: [id])

  items GoodsReceiptItem[]

  @@index([companyId])
  @@index([poId])
  @@map("goods_receipts")
}

enum GoodsReceiptStatus {
  DRAFT
  PENDING_INSPECTION
  INSPECTED
  APPROVED
  REJECTED
  PARTIAL
}

model GoodsReceiptItem {
  id          String    @id @default(uuid())
  grnId       String
  poItemId    String
  materialId  String
  quantity    Decimal   @db.Decimal(15, 3)
  acceptedQty Decimal   @db.Decimal(15, 3)
  rejectedQty Decimal   @default(0) @db.Decimal(15, 3)
  unitPrice   Decimal   @db.Decimal(15, 2)
  totalPrice  Decimal   @db.Decimal(15, 2)
  batchNo     String?
  serialNo    String?
  expiryDate  DateTime?
  remarks     String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  grn      GoodsReceipt      @relation(fields: [grnId], references: [id])
  poItem   PurchaseOrderItem @relation(fields: [poItemId], references: [id])
  material Material          @relation(fields: [materialId], references: [id])

  inventory   Inventory[]
  inspections Inspection[]

  @@index([grnId])
  @@map("goods_receipt_items")
}

// ============================================================
// 10. INVENTORY MODULE
// ============================================================

model Warehouse {
  id        String    @id @default(uuid())
  companyId String
  code      String
  name      String
  location  String?
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  company Company @relation(fields: [companyId], references: [id])

  racks              Rack[]
  inventories        Inventory[]
  stockTransfersFrom StockTransfer[] @relation("StockTransferFrom")
  stockTransfersTo   StockTransfer[] @relation("StockTransferTo")

  @@unique([companyId, code])
  @@index([companyId])
  @@map("warehouses")
}

model Rack {
  id          String    @id @default(uuid())
  warehouseId String
  code        String
  name        String
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  warehouse Warehouse @relation(fields: [warehouseId], references: [id])

  shelves Shelf[]

  @@unique([warehouseId, code])
  @@map("racks")
}

model Shelf {
  id        String    @id @default(uuid())
  rackId    String
  code      String
  name      String
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  rack Rack @relation(fields: [rackId], references: [id])

  bins Bin[]

  @@unique([rackId, code])
  @@map("shelves")
}

model Bin {
  id        String    @id @default(uuid())
  shelfId   String
  code      String
  name      String
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  shelf Shelf @relation(fields: [shelfId], references: [id])

  inventories Inventory[]

  @@unique([shelfId, code])
  @@map("bins")
}

model Inventory {
  id                 String    @id @default(uuid())
  companyId          String
  materialId         String
  warehouseId        String
  binId              String?
  batchNo            String?
  serialNo           String?
  barcode            String?
  qrCode             String?
  quantity           Decimal   @db.Decimal(15, 3)
  reservedQty        Decimal   @default(0) @db.Decimal(15, 3)
  damagedQty         Decimal   @default(0) @db.Decimal(15, 3)
  scrapQty           Decimal   @default(0) @db.Decimal(15, 3)
  transitQty         Decimal   @default(0) @db.Decimal(15, 3)
  stockType          StockType @default(AVAILABLE)
  unitPrice          Decimal   @db.Decimal(15, 2)
  expiryDate         DateTime?
  lastCountedAt      DateTime?
  goodsReceiptItemId String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  deletedAt          DateTime?

  company          Company           @relation(fields: [companyId], references: [id])
  material         Material          @relation(fields: [materialId], references: [id])
  warehouse        Warehouse         @relation(fields: [warehouseId], references: [id])
  bin              Bin?              @relation(fields: [binId], references: [id])
  goodsReceiptItem GoodsReceiptItem? @relation(fields: [goodsReceiptItemId], references: [id])

  transactions   InventoryTransaction[]
  stockTransfers StockTransfer[]

  @@unique([materialId, warehouseId, batchNo, serialNo])
  @@index([companyId])
  @@index([materialId])
  @@index([warehouseId])
  @@map("inventories")
}

enum StockType {
  AVAILABLE
  RESERVED
  DAMAGED
  SCRAP
  TRANSIT
}

model InventoryTransaction {
  id              String          @id @default(uuid())
  inventoryId     String
  transactionType TransactionType
  quantity        Decimal         @db.Decimal(15, 3)
  referenceType   String // PURCHASE, SALES, TRANSFER, ADJUSTMENT, etc
  referenceId     String
  remarks         String?
  createdById     String
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  inventory Inventory @relation(fields: [inventoryId], references: [id])
  createdBy User      @relation(fields: [createdById], references: [id])

  @@index([inventoryId])
  @@index([referenceType, referenceId])
  @@map("inventory_transactions")
}

enum TransactionType {
  IN
  OUT
  ADJUSTMENT
  TRANSFER_IN
  TRANSFER_OUT
  RESERVED
  UNRESERVED
}

model StockTransfer {
  id String @id @default(uuid())

  // Foreign Keys
  companyId       String
  fromWarehouseId String
  toWarehouseId   String
  materialId      String

  requestedById String
  approvedById  String?
  completedById String?
  inventoryId   String?

  company Company @relation(fields: [companyId], references: [id])

  fromWarehouse Warehouse @relation("StockTransferFrom", fields: [fromWarehouseId], references: [id])

  toWarehouse Warehouse @relation("StockTransferTo", fields: [toWarehouseId], references: [id])

  material Material @relation(fields: [materialId], references: [id])

  requestedBy User @relation("StockTransferRequestedBy", fields: [requestedById], references: [id])

  approvedBy User? @relation("StockTransferApprovedBy", fields: [approvedById], references: [id])

  completedBy User? @relation("StockTransferCompletedBy", fields: [completedById], references: [id])

  inventory Inventory? @relation(fields: [inventoryId], references: [id])
}

enum StockTransferStatus {
  REQUESTED
  APPROVED
  COMPLETED
  CANCELLED
}

// ============================================================
// 11. PRODUCTION MODULE
// ============================================================

model ProductionPlan {
  id           String               @id @default(uuid())
  companyId    String
  planNo       String               @unique
  name         String
  description  String?
  startDate    DateTime
  endDate      DateTime?
  status       ProductionPlanStatus @default(DRAFT)
  createdById  String
  approvedById String?
  approvedAt   DateTime?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  deletedAt    DateTime?

  company Company @relation(fields: [companyId], references: [id])

  createdBy  User  @relation("ProductionPlanCreatedBy", fields: [createdById], references: [id])
  approvedBy User? @relation("ProductionPlanApprovedBy", fields: [approvedById], references: [id])

  workOrders WorkOrder[]

  @@index([companyId])
  @@index([status])
  @@map("production_plans")
}

enum ProductionPlanStatus {
  DRAFT
  APPROVED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model WorkOrder {
  id                   String          @id @default(uuid())
  companyId            String
  productionPlanId     String?
  orderNo              String          @unique
  salesOrderId         String?
  productId            String
  quantity             Decimal         @db.Decimal(15, 3)
  startDate            DateTime
  dueDate              DateTime?
  status               WorkOrderStatus @default(DRAFT)
  priority             Priority        @default(MEDIUM)
  assignedToId         String?
  machineId            String?
  completionPercentage Decimal         @default(0) @db.Decimal(5, 2)
  createdById          String
  approvedById         String?
  approvedAt           DateTime?
  completedAt          DateTime?
  remarks              String?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  deletedAt            DateTime?

  company        Company         @relation(fields: [companyId], references: [id])
  productionPlan ProductionPlan? @relation(fields: [productionPlanId], references: [id])
  salesOrder     SalesOrder?     @relation(fields: [salesOrderId], references: [id])
  product        Material        @relation(fields: [productId], references: [id])

  assignedTo User? @relation("WorkOrderAssignedTo", fields: [assignedToId], references: [id])
  createdBy  User  @relation("WorkOrderCreatedBy", fields: [createdById], references: [id])
  approvedBy User? @relation("WorkOrderApprovedBy", fields: [approvedById], references: [id])

  items       WorkOrderItem[]
  logs        ProductionLog[]
  inspections Inspection[]

  @@index([companyId])
  @@index([status])
  @@map("work_orders")
}

enum WorkOrderStatus {
  DRAFT
  APPROVED
  IN_PROGRESS
  ON_HOLD
  COMPLETED
  CANCELLED
}

model WorkOrderItem {
  id          String    @id @default(uuid())
  workOrderId String
  materialId  String
  requiredQty Decimal   @db.Decimal(15, 3)
  consumedQty Decimal   @default(0) @db.Decimal(15, 3)
  wasteQty    Decimal   @default(0) @db.Decimal(15, 3)
  remarks     String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  workOrder WorkOrder @relation(fields: [workOrderId], references: [id])
  material  Material  @relation(fields: [materialId], references: [id])

  @@index([workOrderId])
  @@map("work_order_items")
}

model ProductionLog {
  id          String   @id @default(uuid())
  workOrderId String
  operatorId  String
  machineId   String?
  outputQty   Decimal  @db.Decimal(15, 3)
  rejectedQty Decimal  @default(0) @db.Decimal(15, 3)
  timeSpent   Int? // in minutes
  remarks     String?
  loggedAt    DateTime @default(now())
  createdAt   DateTime @default(now())

  workOrder WorkOrder @relation(fields: [workOrderId], references: [id])
  operator  User      @relation(fields: [operatorId], references: [id])

  @@index([workOrderId])
  @@map("production_logs")
}

// ============================================================
// 12. QUALITY CONTROL MODULE
// ============================================================

model Inspection {
  id                 String           @id @default(uuid())
  companyId          String
  inspectionNo       String           @unique
  inspectionType     InspectionType
  goodsReceiptItemId String?
  workOrderId        String?
  productId          String
  quantity           Decimal          @db.Decimal(15, 3)
  inspectedQty       Decimal          @db.Decimal(15, 3)
  acceptedQty        Decimal          @db.Decimal(15, 3)
  rejectedQty        Decimal          @db.Decimal(15, 3)
  status             InspectionStatus @default(PENDING)
  checklistId        String?
  inspectedById      String
  approvedById       String?
  approvedAt         DateTime?
  remarks            String?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  deletedAt          DateTime?

  company          Company              @relation(fields: [companyId], references: [id])
  goodsReceiptItem GoodsReceiptItem?    @relation(fields: [goodsReceiptItemId], references: [id])
  workOrder        WorkOrder?           @relation(fields: [workOrderId], references: [id])
  product          Material             @relation(fields: [productId], references: [id])
  checklist        InspectionChecklist? @relation(fields: [checklistId], references: [id])

  inspectedBy User  @relation("InspectionInspectedBy", fields: [inspectedById], references: [id])
  approvedBy  User? @relation("InspectionApprovedBy", fields: [approvedById], references: [id])

  results InspectionResult[]
  defects Defect[]
  reworks Rework[]

  @@index([companyId])
  @@index([inspectionType])
  @@index([status])
  @@map("inspections")
}

enum InspectionType {
  INCOMING
  PRODUCTION
  FINAL
}

enum InspectionStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  APPROVED
  REJECTED
}

model InspectionChecklist {
  id             String         @id @default(uuid())
  companyId      String
  name           String
  description    String?
  inspectionType InspectionType
  isActive       Boolean        @default(true)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  deletedAt      DateTime?

  company Company @relation(fields: [companyId], references: [id])

  inspections Inspection[]

  @@index([companyId])
  @@map("inspection_checklists")
}

model InspectionResult {
  id           String   @id @default(uuid())
  inspectionId String
  parameter    String
  value        String?
  expected     String?
  isPass       Boolean
  remarks      String?
  createdAt    DateTime @default(now())

  inspection Inspection @relation(fields: [inspectionId], references: [id])

  @@index([inspectionId])
  @@map("inspection_results")
}

model Defect {
  id           String         @id @default(uuid())
  inspectionId String
  defectType   String
  description  String
  quantity     Decimal        @db.Decimal(15, 3)
  severity     DefectSeverity @default(MINOR)
  remarks      String?
  createdAt    DateTime       @default(now())

  inspection Inspection @relation(fields: [inspectionId], references: [id])

  @@index([inspectionId])
  @@map("defects")
}

enum DefectSeverity {
  MINOR
  MAJOR
  CRITICAL
}

model Rework {
  id           String       @id @default(uuid())
  inspectionId String
  description  String
  quantity     Decimal      @db.Decimal(15, 3)
  reworkType   String
  assignedToId String
  status       ReworkStatus @default(PENDING)
  completedAt  DateTime?
  remarks      String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  deletedAt    DateTime?

  inspection Inspection @relation(fields: [inspectionId], references: [id])
  assignedTo User       @relation(fields: [assignedToId], references: [id])

  @@index([inspectionId])
  @@map("reworks")
}

enum ReworkStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  REJECTED
}

// ============================================================
// 13. DISPATCH MODULE
// ============================================================

model Dispatch {
  id            String         @id @default(uuid())
  companyId     String
  dispatchNo    String         @unique
  salesOrderId  String
  vehicleId     String?
  driverName    String?
  driverPhone   String?
  lrNumber      String? // LR - Lorry Receipt
  ewayBillNo    String?
  dispatchDate  DateTime       @default(now())
  deliveredDate DateTime?
  status        DispatchStatus @default(PENDING)
  deliveryProof String? // URL to delivery proof document
  remarks       String?
  createdById   String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  deletedAt     DateTime?

  company    Company    @relation(fields: [companyId], references: [id])
  salesOrder SalesOrder @relation(fields: [salesOrderId], references: [id])
  vehicle    Vehicle?   @relation(fields: [vehicleId], references: [id])
  createdBy  User       @relation(fields: [createdById], references: [id])

  items          DispatchItem[]
  deliveryProofs DeliveryProof[]

  @@index([companyId])
  @@index([status])
  @@map("dispatches")
}

enum DispatchStatus {
  PENDING
  DISPATCHED
  IN_TRANSIT
  DELIVERED
  CANCELLED
}

model DispatchItem {
  id               String    @id @default(uuid())
  dispatchId       String
  salesOrderItemId String
  quantity         Decimal   @db.Decimal(15, 3)
  batchNo          String?
  serialNo         String?
  remarks          String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?

  dispatch       Dispatch       @relation(fields: [dispatchId], references: [id])
  salesOrderItem SalesOrderItem @relation(fields: [salesOrderItemId], references: [id])

  @@index([dispatchId])
  @@map("dispatch_items")
}

model Vehicle {
  id        String    @id @default(uuid())
  companyId String
  vehicleNo String    @unique
  type      String // TRUCK, VAN, etc
  capacity  Decimal?  @db.Decimal(10, 2)
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  company Company @relation(fields: [companyId], references: [id])

  dispatches Dispatch[]

  @@index([companyId])
  @@map("vehicles")
}

model DeliveryProof {
  id           String   @id @default(uuid())
  dispatchId   String
  fileName     String
  fileUrl      String
  fileSize     Int?
  mimeType     String?
  uploadedById String
  createdAt    DateTime @default(now())

  dispatch   Dispatch @relation(fields: [dispatchId], references: [id])
  uploadedBy User     @relation(fields: [uploadedById], references: [id])

  @@index([dispatchId])
  @@map("delivery_proofs")
}

// ============================================================
// 14. FINANCE MODULE
// ============================================================

model Invoice {
  id              String        @id @default(uuid())
  companyId       String
  invoiceNo       String        @unique
  invoiceType     InvoiceType   @default(SALES)
  salesOrderId    String?
  purchaseOrderId String?
  customerId      String?
  vendorId        String?
  invoiceDate     DateTime      @default(now())
  dueDate         DateTime?
  subtotal        Decimal       @db.Decimal(15, 2)
  tax             Decimal       @db.Decimal(15, 2)
  discount        Decimal       @default(0) @db.Decimal(15, 2)
  total           Decimal       @db.Decimal(15, 2)
  paidAmount      Decimal       @default(0) @db.Decimal(15, 2)
  outstanding     Decimal       @db.Decimal(15, 2)
  currency        String        @default("INR")
  status          InvoiceStatus @default(DRAFT)
  gstAmount       Decimal?      @db.Decimal(15, 2)
  tdsAmount       Decimal?      @db.Decimal(15, 2)
  createdById     String
  approvedById    String?
  approvedAt      DateTime?
  remarks         String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  deletedAt       DateTime?

  company       Company        @relation(fields: [companyId], references: [id])
  salesOrder    SalesOrder?    @relation(fields: [salesOrderId], references: [id])
  purchaseOrder PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id])
  customer      Customer?      @relation(fields: [customerId], references: [id])
  vendor        Customer?      @relation("VendorInvoices", fields: [vendorId], references: [id])

  createdBy  User  @relation("InvoiceCreatedBy", fields: [createdById], references: [id])
  approvedBy User? @relation("InvoiceApprovedBy", fields: [approvedById], references: [id])

  items         InvoiceItem[]
  payments      Payment[]
  creditNotes   CreditNote[]
  debitNotes    DebitNote[]
  ledgerEntries LedgerEntry[]

  @@index([companyId])
  @@index([status])
  @@index([invoiceNo])
  @@map("invoices")
}

enum InvoiceType {
  SALES
  PURCHASE
  CREDIT_NOTE
  DEBIT_NOTE
}

enum InvoiceStatus {
  DRAFT
  APPROVED
  SENT
  PARTIAL_PAID
  PAID
  OVERDUE
  CANCELLED
}

model InvoiceItem {
  id          String    @id @default(uuid())
  invoiceId   String
  description String
  quantity    Decimal   @db.Decimal(15, 3)
  unitPrice   Decimal   @db.Decimal(15, 2)
  totalPrice  Decimal   @db.Decimal(15, 2)
  taxRate     Decimal?  @db.Decimal(5, 2)
  taxAmount   Decimal?  @db.Decimal(15, 2)
  remarks     String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  invoice Invoice @relation(fields: [invoiceId], references: [id])

  @@index([invoiceId])
  @@map("invoice_items")
}

model Payment {
  id            String        @id @default(uuid())
  companyId     String
  paymentNo     String        @unique
  invoiceId     String
  amount        Decimal       @db.Decimal(15, 2)
  paymentDate   DateTime      @default(now())
  paymentMethod PaymentMethod @default(CASH)
  referenceNo   String?
  remarks       String?
  receivedById  String
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  deletedAt     DateTime?

  company    Company @relation(fields: [companyId], references: [id])
  invoice    Invoice @relation(fields: [invoiceId], references: [id])
  receivedBy User    @relation(fields: [receivedById], references: [id])

  @@index([companyId])
  @@index([invoiceId])
  @@map("payments")
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  CHEQUE
  DD
  CREDIT_CARD
  DEBIT_CARD
  UPI
  NEFT
  RTGS
  IMPS
}

model CreditNote {
  id           String    @id @default(uuid())
  companyId    String
  creditNoteNo String    @unique
  invoiceId    String
  amount       Decimal   @db.Decimal(15, 2)
  reason       String
  createdById  String
  approvedById String?
  approvedAt   DateTime?
  remarks      String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  company Company @relation(fields: [companyId], references: [id])
  invoice Invoice @relation(fields: [invoiceId], references: [id])

  createdBy  User  @relation("CreditNoteCreatedBy", fields: [createdById], references: [id])
  approvedBy User? @relation("CreditNoteApprovedBy", fields: [approvedById], references: [id])

  @@index([companyId])
  @@index([invoiceId])
  @@map("credit_notes")
}

model DebitNote {
  id           String    @id @default(uuid())
  companyId    String
  debitNoteNo  String    @unique
  invoiceId    String
  amount       Decimal   @db.Decimal(15, 2)
  reason       String
  createdById  String
  approvedById String?
  approvedAt   DateTime?
  remarks      String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  company Company @relation(fields: [companyId], references: [id])
  invoice Invoice @relation(fields: [invoiceId], references: [id])

  createdBy  User  @relation("DebitNoteCreatedBy", fields: [createdById], references: [id])
  approvedBy User? @relation("DebitNoteApprovedBy", fields: [approvedById], references: [id])

  @@index([companyId])
  @@index([invoiceId])
  @@map("debit_notes")
}

model Expense {
  id           String    @id @default(uuid())
  companyId    String
  expenseNo    String    @unique
  category     String
  amount       Decimal   @db.Decimal(15, 2)
  expenseDate  DateTime  @default(now())
  description  String
  referenceNo  String?
  approvedById String?
  approvedAt   DateTime?
  createdById  String
  remarks      String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  company Company @relation(fields: [companyId], references: [id])

  approvedBy User? @relation("ExpenseApprovedBy", fields: [approvedById], references: [id])
  createdBy  User  @relation("ExpenseCreatedBy", fields: [createdById], references: [id])

  ledgerEntries LedgerEntry[]

  @@index([companyId])
  @@index([category])
  @@map("expenses")
}

model LedgerEntry {
  id            String    @id @default(uuid())
  companyId     String
  entryNo       String    @unique
  account       String
  debit         Decimal?  @db.Decimal(15, 2)
  credit        Decimal?  @db.Decimal(15, 2)
  balance       Decimal?  @db.Decimal(15, 2)
  entryDate     DateTime  @default(now())
  description   String
  referenceType String? // INVOICE, PAYMENT, EXPENSE, etc
  referenceId   String?
  createdById   String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  company   Company  @relation(fields: [companyId], references: [id])
  invoice   Invoice? @relation(fields: [referenceId], references: [id], map: "ledger_entries_invoice_referenceId_fkey")
  expense   Expense? @relation(fields: [referenceId], references: [id], map: "ledger_entries_expense_referenceId_fkey")
  createdBy User     @relation(fields: [createdById], references: [id])

  @@index([companyId])
  @@index([account])
  @@index([entryDate])
  @@map("ledger_entries")
}

// ============================================================
// 15. REPORTING MODULE
// ============================================================

model ReportDefinition {
  id           String    @id @default(uuid())
  companyId    String
  name         String
  description  String?
  reportType   String // SALES, PURCHASE, INVENTORY, FINANCE, etc
  query        String // SQL query or report definition
  parameters   Json? // Report parameters schema
  outputFormat String // PDF, EXCEL, CSV, etc
  isSystem     Boolean   @default(false)
  isActive     Boolean   @default(true)
  createdById  String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  company   Company @relation(fields: [companyId], references: [id])
  createdBy User    @relation(fields: [createdById], references: [id])

  schedules ReportSchedule[]
  widgets   DashboardWidget[]

  @@unique([companyId, name])
  @@index([companyId])
  @@map("report_definitions")
}

model ReportSchedule {
  id          String            @id @default(uuid())
  companyId   String
  reportId    String
  name        String
  frequency   ScheduleFrequency
  dayOfWeek   Int? // 1-7 for weekly
  dayOfMonth  Int? // 1-31 for monthly
  time        String // HH:mm format
  recipients  String[] // Email addresses
  formats     String[] // Output formats
  isActive    Boolean           @default(true)
  lastRunAt   DateTime?
  nextRunAt   DateTime?
  createdById String
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  deletedAt   DateTime?

  company   Company          @relation(fields: [companyId], references: [id])
  report    ReportDefinition @relation(fields: [reportId], references: [id])
  createdBy User             @relation(fields: [createdById], references: [id])

  @@index([companyId])
  @@index([reportId])
  @@map("report_schedules")
}

enum ScheduleFrequency {
  DAILY
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
  CUSTOM
}

model DashboardWidget {
  id            String    @id @default(uuid())
  companyId     String
  reportId      String
  name          String
  widgetType    String // CHART, TABLE, KPI, METRIC
  configuration Json // Chart config, filters, etc
  position      Int // Order on dashboard
  isActive      Boolean   @default(true)
  createdById   String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  company   Company          @relation(fields: [companyId], references: [id])
  report    ReportDefinition @relation(fields: [reportId], references: [id])
  createdBy User             @relation(fields: [createdById], references: [id])

  @@index([companyId])
  @@map("dashboard_widgets")
}

// ============================================================
// ENUMS USED ACROSS MODULES
// ============================================================

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model Vendor {
  id String @id @default(uuid())

  companyId String

  name     String
  category String?

  contactPerson String?
  phone         String?
  email         String?
  gstNumber     String?

  address String?
  notes   String?

  revisionCount Int @default(0)

  createdById String

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  company   Company @relation(fields: [companyId], references: [id])
  createdBy User    @relation("VendorCreatedBy", fields: [createdById], references: [id])

  revisions VendorRevision[]

  @@index([companyId])
  @@index([name])
  @@index([category])
  @@map("vendors")
}

model VendorRevision {
  id String @id @default(uuid())

  vendorId String

  action String

  oldData Json?
  newData Json?

  createdById String

  createdAt DateTime @default(now())

  vendor Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  createdBy User @relation("VendorRevisionCreatedBy", fields: [createdById], references: [id])

  @@index([vendorId])
  @@map("vendor_revisions")
}
