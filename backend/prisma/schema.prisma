// Manufacturing ERP - Phase 1 Database Schema
// Modules: Authentication, Organization, PRBAC,
//          Employee Management (HRMS), CRM, Lead Management

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 1. ORGANIZATION MANAGEMENT
model Company {
  id        String    @id @default(uuid())
  name      String
  gst       String?   @unique
  pan       String?   @unique
  email     String?
  phone     String?
  address   String?
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  vendors   Vendor[]

  branches                Branch[]
  users                   User[]
  costCenters             CostCenter[]
  customers               Customer[]
  tenderRequests          TenderRequest[]
  roles                   Role[]
  employees               Employee[]
  tenders                 Tender[]
  governmentDepartments   GovernmentDepartment[]
  sections                Section[]
  divisions               Division[]
  subDivisions            SubDivision[]
  referenceCodeCounters   ReferenceCodeCounter[]
  technicalClarifications TechnicalClarification[]
  boqs                    BOQ[]
  quotations              Quotation[]
  approvalWorkflows       ApprovalWorkflow[]
  approvalRequests        ApprovalRequest[]
  salesOrders             SalesOrder[]
  engineeringProjects     EngineeringProject[]
  boms                    BOM[]
  materials               Material[]
  materialCategories      MaterialCategory[]
  materialBrands          MaterialBrand[]
  materialSpecifications  MaterialSpecification[]
  purchaseRequests        PurchaseRequest[]
  purchaseOrders          PurchaseOrder[]
  goodsReceipts           GoodsReceipt[]
  warehouses              Warehouse[]
  inventories             Inventory[]
  stockTransfers          StockTransfer[]
  productionPlans         ProductionPlan[]
  workOrders              WorkOrder[]
  inspections             Inspection[]
  inspectionChecklists    InspectionChecklist[]
  dispatches              Dispatch[]
  vehicles                Vehicle[]
  invoices                Invoice[]
  payments                Payment[]
  creditNotes             CreditNote[]
  debitNotes              DebitNote[]
  expenses                Expense[]
  ledgerEntries           LedgerEntry[]
  reportDefinitions       ReportDefinition[]
  reportSchedules         ReportSchedule[]
  dashboardWidgets        DashboardWidget[]

  @@map("companies")
}

model Branch {
  id        String  @id @default(uuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  name     String
  code     String
  address  String?
  city     String?
  state    String?
  pincode  String?
  isActive Boolean @default(true)

  departments Department[]
  employees   Employee[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([companyId, code])
  @@map("branches")
}

model Department {
  id       String @id @default(uuid())
  branchId String
  branch   Branch @relation(fields: [branchId], references: [id])

  name     String
  code     String
  isActive Boolean @default(true)

  teams       Team[]
  employees   Employee[]
  costCenters CostCenter[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  tenders   Tender[]
  sections  Section[]

  @@unique([branchId, code])
  @@map("departments")
}

model Team {
  id           String     @id @default(uuid())
  departmentId String
  department   Department @relation(fields: [departmentId], references: [id])

  name     String
  isActive Boolean @default(true)

  employees Employee[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@map("teams")
}

model Designation {
  id    String @id @default(uuid())
  title String @unique
  level Int? // seniority level, useful for approval hierarchy later

  employees Employee[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@map("designations")
}

model CostCenter {
  id           String      @id @default(uuid())
  companyId    String
  company      Company     @relation(fields: [companyId], references: [id])
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])

  code   String
  name   String
  budget Decimal? @db.Decimal(15, 2)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([companyId, code])
  @@map("cost_centers")
}

// 2. AUTHENTICATION
model User {
  id        String  @id @default(uuid())
  name      String
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  email           String  @unique
  phone           String? @unique
  passwordHash    String
  isEmailVerified Boolean @default(false)
  isPhoneVerified Boolean @default(false)
  isActive        Boolean @default(true)

  employee Employee?

  refreshTokens   RefreshToken[]
  sessions        UserSession[]
  otpRequests     OtpRequest[]
  passwordResets  PasswordReset[]
  userRoles       UserRole[]
  userPermissions UserPermission[]

  tenderRequestsAssigned TenderRequest[]        @relation("TenderRequestAssignedTo")
  communicationLogs      CommunicationHistory[]
  auditLogs              AuditLog[]

  quotationsCreated  Quotation[] @relation("QuotationCreatedBy")
  quotationsApproved Quotation[] @relation("QuotationApprovedBy")
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  deletedAt          DateTime?

  tendersCreated                    Tender[]                           @relation("TenderCreatedBy")
  tendersAssigned                   Tender[]                           @relation("TenderAssignedTo")
  tenderRemarks                     TenderRemark[]
  technicalClarificationsRaised     TechnicalClarification[]           @relation("TechnicalClarificationRaisedBy")
  technicalClarificationsAssigned   TechnicalClarification[]           @relation("TechnicalClarificationAssignedTo")
  technicalClarificationReplies     TechnicalClarificationReply[]
  technicalClarificationAttachments TechnicalClarificationAttachment[]
  technicalClarificationActivities  TechnicalClarificationActivity[]

  boqattachments       BOQAttachment[]
  quotationRevisions   QuotationRevision[]
  quotationAttachments QuotationAttachment[]

  completedStockTransfers StockTransfer[] @relation("StockTransferCompletedBy")

  approvalRequestsRequested ApprovalRequest[] @relation("ApprovalRequestRequestedBy")
  approvalRequestsAssigned  ApprovalRequest[] @relation("ApprovalRequestAssignedTo")
  approvalHistories         ApprovalHistory[]

  salesOrderAttachments      SalesOrderAttachment[]
  engineeringProjectsCreated EngineeringProject[]   @relation("EngineeringProjectCreatedBy")

  engineeringProjectsApproved EngineeringProject[]   @relation("EngineeringProjectApprovedBy")
  approvedDrawings            EngineeringDrawing[]   @relation("DrawingApprovedBy")
  createdDrawings             EngineeringDrawing[]   @relation("DrawingCreatedBy")
  approvedRevisions           DrawingRevision[]      @relation("RevisionApprovedBy")
  createdRevisions            DrawingRevision[]      @relation("RevisionCreatedBy")
  approvedBOMs                BOM[]                  @relation("BOMApprovedBy")
  createdBOMs                 BOM[]                  @relation("BOMCreatedBy")
  bomrevisions                BOMRevision[]
  materials                   Material[]
  requestedPurchaseRequests   PurchaseRequest[]      @relation("PurchaseRequestRequestedBy")
  approvedPurchaseRequests    PurchaseRequest[]      @relation("PurchaseRequestApprovedBy")
  createdPurchaseOrders       PurchaseOrder[]        @relation("PurchaseOrderCreatedBy")
  approvedPurchaseOrders      PurchaseOrder[]        @relation("PurchaseOrderApprovedBy")
  receivedGoodsReceipts       GoodsReceipt[]         @relation("GoodsReceiptReceivedBy")
  approvedGoodsReceipts       GoodsReceipt[]         @relation("GoodsReceiptApprovedBy")
  inventoryTransactions       InventoryTransaction[]
  requestedStockTransfers     StockTransfer[]        @relation("StockTransferRequestedBy")
  approvedStockTransfers      StockTransfer[]        @relation("StockTransferApprovedBy")

  createdProductionPlans  ProductionPlan[]   @relation("ProductionPlanCreatedBy")
  approvedProductionPlans ProductionPlan[]   @relation("ProductionPlanApprovedBy")
  assignedWorkOrders      WorkOrder[]        @relation("WorkOrderAssignedTo")
  createdWorkOrders       WorkOrder[]        @relation("WorkOrderCreatedBy")
  approvedWorkOrders      WorkOrder[]        @relation("WorkOrderApprovedBy")
  productionLogs          ProductionLog[]
  inspectedInspections    Inspection[]       @relation("InspectionInspectedBy")
  approvedInspections     Inspection[]       @relation("InspectionApprovedBy")
  reworks                 Rework[]
  dispatches              Dispatch[]
  deliveryProofs          DeliveryProof[]
  createdInvoices         Invoice[]          @relation("InvoiceCreatedBy")
  approvedInvoices        Invoice[]          @relation("InvoiceApprovedBy")
  payments                Payment[]
  createdCreditNotes      CreditNote[]       @relation("CreditNoteCreatedBy")
  approvedCreditNotes     CreditNote[]       @relation("CreditNoteApprovedBy")
  createdDebitNotes       DebitNote[]        @relation("DebitNoteCreatedBy")
  approvedDebitNotes      DebitNote[]        @relation("DebitNoteApprovedBy")
  approvedExpenses        Expense[]          @relation("ExpenseApprovedBy")
  createdExpenses         Expense[]          @relation("ExpenseCreatedBy")
  ledgerEntries           LedgerEntry[]
  reportDefinitions       ReportDefinition[]
  reportSchedules         ReportSchedule[]
  dashboardWidgets        DashboardWidget[]

  orderAssignments   SalesOrderAssignment[]
  salesOrdersTaken   SalesOrder[]           @relation("OrderTakenBy")
  salesOrdersCreated SalesOrder[]           @relation("OrderCreatedBy")

  @@index([companyId])
  @@map("users")
}

model RefreshToken {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  token     String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  ipAddress String
  userAgent String?

  createdAt DateTime @default(now())

  @@index([userId])
  @@map("refresh_tokens")
}

model UserSession {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  deviceId    String?
  deviceName  String?
  ipAddress   String?
  userAgent   String?
  loggedOutAt DateTime?
  lastSeenAt  DateTime  @default(now())

  createdAt DateTime @default(now())

  @@index([userId])
  @@map("user_sessions")
}

model OtpRequest {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  otpHash    String
  purpose    OtpPurpose
  expiresAt  DateTime
  consumedAt DateTime?
  attempts   Int        @default(0)

  createdAt DateTime @default(now())

  @@index([userId])
  @@map("otp_requests")
}

enum OtpPurpose {
  LOGIN
  PHONE_VERIFICATION
  PASSWORD_RESET
}

model PasswordReset {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?

  requestedIp        String?
  requestedUserAgent String?

  createdAt DateTime @default(now())

  @@index([userId])
  @@map("password_resets")
}

// 3. PRBAC (Policy & Permission Based Access Control)
model Role {
  id        String  @id @default(uuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  name        String // e.g. "Sales Executive", "Sales Manager", "Director"
  description String?
  isSystem    Boolean @default(false) // prevents deletion of core roles

  rolePermissions RolePermission[]
  userRoles       UserRole[]

  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  deletedAt      DateTime?
  approvalLevels ApprovalLevel[]

  @@unique([companyId, name])
  @@map("roles")
}

model PermissionGroup {
  id          String  @id @default(uuid())
  name        String  @unique // e.g. "Tender Management"
  description String?

  permissions Permission[]

  @@map("permission_groups")
}

model Permission {
  id      String           @id @default(uuid())
  groupId String?
  group   PermissionGroup? @relation(fields: [groupId], references: [id])

  code            String           @unique // e.g. "tender.create", "tender.approve"
  description     String?
  userPermissions UserPermission[]
  rolePermissions RolePermission[]

  @@map("permissions")
}

model RolePermission {
  id           String     @id @default(uuid())
  roleId       String
  role         Role       @relation(fields: [roleId], references: [id])
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id])

  createdAt DateTime @default(now())

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model UserRole {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])
  roleId String
  role   Role   @relation(fields: [roleId], references: [id])

  createdAt DateTime @default(now())

  @@unique([userId, roleId])
  @@map("user_roles")
}

// Explicit allow/deny overrides for a specific user, on top of role permissions
model UserPermission {
  id String @id @default(uuid())

  userId       String
  permissionId String

  allowed Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user       User       @relation(fields: [userId], references: [id])
  permission Permission @relation(fields: [permissionId], references: [id])

  @@unique([userId, permissionId])
}

enum OverrideEffect {
  ALLOW
  DENY
}

// 4. EMPLOYEE MANAGEMENT (HRMS)
model Employee {
  id     String  @id @default(uuid())
  userId String? @unique
  user   User?   @relation(fields: [userId], references: [id])

  companyId     String
  company       Company      @relation(fields: [companyId], references: [id])
  branchId      String?
  branch        Branch?      @relation(fields: [branchId], references: [id])
  departmentId  String?
  department    Department?  @relation(fields: [departmentId], references: [id])
  teamId        String?
  team          Team?        @relation(fields: [teamId], references: [id])
  designationId String?
  designation   Designation? @relation(fields: [designationId], references: [id])
  reportsToId   String?
  reportsTo     Employee?    @relation("EmployeeHierarchy", fields: [reportsToId], references: [id])
  subordinates  Employee[]   @relation("EmployeeHierarchy")

  employeeCode  String         @unique
  firstName     String
  lastName      String
  dateOfBirth   DateTime?
  gender        String?
  dateOfJoining DateTime?
  dateOfExit    DateTime?
  status        EmployeeStatus @default(ACTIVE)

  contacts              EmployeeContact[]
  emergencyContacts     EmployeeEmergencyContact[]
  education             EmployeeEducation[]
  experience            EmployeeExperience[]
  documents             EmployeeDocument[]
  attendances           Attendance[]
  leaves                Leave[]
  shiftAssignments      EmployeeShift[]
  salaries              Salary[]
  tenderRequestsCreated TenderRequest[]            @relation("TenderRequestCreatedBy")

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([companyId])
  @@map("employees")
}

enum EmployeeStatus {
  ACTIVE
  ON_LEAVE
  SUSPENDED
  RESIGNED
  TERMINATED
}

model EmployeeContact {
  id         String   @id @default(uuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])

  type      ContactType // PHONE, EMAIL, ADDRESS
  value     String
  isPrimary Boolean     @default(false)

  createdAt DateTime @default(now())

  @@map("employee_contacts")
}

enum ContactType {
  PHONE
  EMAIL
  ADDRESS
}

model EmployeeEmergencyContact {
  id         String   @id @default(uuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])

  name         String
  relationship String
  phone        String

  createdAt DateTime @default(now())

  @@map("employee_emergency_contacts")
}

model EmployeeEducation {
  id         String   @id @default(uuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])

  degree        String
  institution   String
  yearOfPassing Int?
  grade         String?

  createdAt DateTime @default(now())

  @@map("employee_education")
}

model EmployeeExperience {
  id         String   @id @default(uuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])

  companyName String
  designation String
  fromDate    DateTime?
  toDate      DateTime?

  createdAt DateTime @default(now())

  @@map("employee_experience")
}

model EmployeeDocument {
  id         String   @id @default(uuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])

  documentType String // e.g. AADHAR, PAN, RESUME, OFFER_LETTER
  fileUrl      String // MinIO object path
  fileName     String

  createdAt DateTime @default(now())

  @@map("employee_documents")
}

model Shift {
  id String @id @default(uuid())

  name        String          @unique
  startTime   String
  endTime     String
  assignments EmployeeShift[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@map("shifts")
}

model EmployeeShift {
  id         String   @id @default(uuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])
  shiftId    String
  shift      Shift    @relation(fields: [shiftId], references: [id])

  effectiveFrom DateTime
  effectiveTo   DateTime?

  @@map("employee_shifts")
}

model Holiday {
  id   String   @id @default(uuid())
  name String   @unique
  date DateTime
  type String? // NATIONAL, OPTIONAL, etc

  @@map("holidays")
}

model Attendance {
  id         String   @id @default(uuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])

  date     DateTime
  checkIn  DateTime?
  checkOut DateTime?
  status   AttendanceStatus @default(PRESENT)
  remarks  String?

  createdAt DateTime @default(now())

  @@unique([employeeId, date])
  @@index([employeeId])
  @@map("attendance")
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  HALF_DAY
  ON_LEAVE
  HOLIDAY
}

model Leave {
  id         String   @id @default(uuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])

  leaveType    String // CASUAL, SICK, EARNED, etc
  fromDate     DateTime
  toDate       DateTime
  reason       String?
  status       LeaveStatus @default(PENDING)
  approvedById String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([employeeId])
  @@map("leaves")
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

model Salary {
  id         String   @id @default(uuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])

  effectiveFrom DateTime
  basic         Decimal  @db.Decimal(12, 2)
  hra           Decimal  @default(0) @db.Decimal(12, 2)
  allowances    Decimal  @default(0) @db.Decimal(12, 2)
  deductions    Decimal  @default(0) @db.Decimal(12, 2)
  ctc           Decimal  @db.Decimal(12, 2)

  createdAt DateTime @default(now())

  @@index([employeeId])
  @@map("salaries")
}

// 5. CRM (Customer Relationship Management)
model Customer {
  id        String  @id @default(uuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  name            String
  gst             String?
  pan             String?
  billingAddress  String?
  shippingAddress String?
  paymentTerms    String?
  firmName        String?
  isGovernment    Boolean @default(false)
  isActive        Boolean @default(true)

  contacts          ContactPerson[]
  communicationLogs CommunicationHistory[]
  tenderRequests    TenderRequest[]

  tenders        Tender[]
  quotations     Quotation[]
  salesOrders    SalesOrder[]
  purchaseOrders PurchaseOrder[]
  invoices       Invoice[]
  vendorInvoices Invoice[]       @relation("VendorInvoices")

  // Audit Fields
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([companyId])
  @@map("customers")
}

model ContactPerson {
  id         String   @id @default(uuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])

  name        String
  designation String?
  phone       String?
  email       String?
  isPrimary   Boolean @default(false)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@map("contact_persons")
}

model CommunicationHistory {
  id         String   @id @default(uuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])
  userId     String?
  user       User?    @relation(fields: [userId], references: [id])

  type    CommunicationType // CALL, EMAIL, WHATSAPP, SMS, NOTE
  subject String?
  content String?

  createdAt DateTime @default(now())

  @@index([customerId])
  @@map("communication_history")
}

enum CommunicationType {
  CALL
  EMAIL
  WHATSAPP
  SMS
  NOTE
}

//6. TENDER MANAGEMENT
model Tender {
  id String @id @default(uuid())

  companyId       String
  tenderRequestId String?
  customerId      String?

  departmentId  String?
  sectionId     String?
  divisionId    String?
  subDivisionId String?

  tenderNo   String?
  tenderCode String? @unique

  title       String
  description String?

  projectLocation String?
  estimatedCost   Decimal? @db.Decimal(15, 2)

  publishedAt DateTime?
  dueDate     DateTime?

  status TenderStatus @default(DRAFT)

  createdById  String
  assignedToId String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  company Company @relation(fields: [companyId], references: [id])

  tenderRequest TenderRequest? @relation(fields: [tenderRequestId], references: [id])

  customer Customer? @relation(fields: [customerId], references: [id])

  department Department? @relation(fields: [departmentId], references: [id])

  section Section? @relation(fields: [sectionId], references: [id])

  division Division? @relation(fields: [divisionId], references: [id])

  subDivision SubDivision? @relation(fields: [subDivisionId], references: [id])

  createdBy User @relation("TenderCreatedBy", fields: [createdById], references: [id])

  assignedTo User? @relation("TenderAssignedTo", fields: [assignedToId], references: [id])

  files                   TenderFile[]
  remarks                 TenderRemark[]
  activities              TenderActivity[]
  referenceCodes          ReferenceCode[]
  governmentDepartment    GovernmentDepartment?    @relation(fields: [governmentDepartmentId], references: [id])
  governmentDepartmentId  String?
  technicalClarifications TechnicalClarification[]
  boqs                    BOQ[]
  quotations              Quotation[]
  salesOrders             SalesOrder[]

  @@index([companyId])
  @@index([status])
  @@index([dueDate])
  @@map("tenders")
}

model TenderFile {
  id String @id @default(uuid())

  tenderId String

  fileName String
  fileUrl  String
  fileType String?

  uploadedBy String?

  createdAt DateTime @default(now())

  tender Tender @relation(fields: [tenderId], references: [id])

  @@map("tender_files")
}

model TenderRemark {
  id String @id @default(uuid())

  tenderId String
  userId   String?

  remark String

  createdAt DateTime @default(now())

  tender Tender @relation(fields: [tenderId], references: [id])

  user User? @relation(fields: [userId], references: [id])

  @@map("tender_remarks")
}

enum TenderStatus {
  DRAFT
  OPEN
  ASSIGNED
  IN_PROGRESS
  SUBMITTED
  COMPLETED
  CANCELLED
}

model TenderRequest {
  id        String  @id @default(uuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id])

  assignedToId String?
  assignedTo   User?   @relation("TenderRequestAssignedTo", fields: [assignedToId], references: [id])

  createdById String?
  createdBy   Employee? @relation("TenderRequestCreatedBy", fields: [createdById], references: [id])

  source         TenderRequestSource @default(WEBSITE)
  status         TenderRequestStatus @default(NEW)
  title          String
  description    String?
  estimatedValue Decimal?            @db.Decimal(15, 2)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  tenders   Tender[]

  @@index([companyId])
  @@index([assignedToId])
  @@map("tender_requests")
}

enum TenderRequestSource {
  WEBSITE
  REFERRAL
  EMAIL
  WHATSAPP
  MANUAL
}

enum TenderRequestStatus {
  NEW
  ASSIGNED
  CONTACTED
  QUALIFIED
  TENDER
  QUOTATION
  WON
  LOST
}

model TenderActivity {
  id String @id @default(uuid())

  tenderId String

  action   String
  oldValue Json?
  newValue Json?

  performedBy String?

  createdAt DateTime @default(now())

  tender Tender @relation(fields: [tenderId], references: [id])

  @@map("tender_activities")
}

model GovernmentDepartment {
  id        String @id @default(uuid())
  companyId String

  name      String
  code      String?
  shortName String? // MES, CPWD, PWD

  isActive Boolean @default(true)

  company Company @relation(fields: [companyId], references: [id])

  sections Section[]
  tenders  Tender[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, name])
  @@map("government_departments")
}

model Section {
  id           String @id @default(uuid())
  companyId    String
  departmentId String

  name     String
  code     String?
  isActive Boolean @default(true)

  company    Company    @relation(fields: [companyId], references: [id])
  department Department @relation(fields: [departmentId], references: [id])

  divisions Division[]

  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @updatedAt
  deletedAt              DateTime?
  tenders                Tender[]
  governmentDepartment   GovernmentDepartment? @relation(fields: [governmentDepartmentId], references: [id])
  governmentDepartmentId String?

  @@unique([departmentId, name])
  @@map("sections")
}

model Division {
  id        String @id @default(uuid())
  companyId String
  sectionId String

  name     String
  code     String?
  isActive Boolean @default(true)

  company Company @relation(fields: [companyId], references: [id])
  section Section @relation(fields: [sectionId], references: [id])

  subDivisions SubDivision[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  tenders   Tender[]

  @@unique([sectionId, name])
  @@map("divisions")
}

model SubDivision {
  id         String @id @default(uuid())
  companyId  String
  divisionId String

  name     String
  code     String?
  isActive Boolean @default(true)

  company  Company  @relation(fields: [companyId], references: [id])
  division Division @relation(fields: [divisionId], references: [id])

  tenders Tender[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([divisionId, name])
  @@map("sub_divisions")
}

// CROSS-CUTTING: AUDIT LOG
// (Included in Phase 1 since every module above needs it from day one)
model AuditLog {
  id     String  @id @default(uuid())
  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  module    String // e.g. "Lead", "Tender"
  recordId  String
  action    String // CREATE, UPDATE, DELETE, APPROVE, etc
  oldValue  Json?
  newValue  Json?
  ipAddress String?
  userAgent String?

  createdAt DateTime @default(now())

  @@index([module, recordId])
  @@map("audit_logs")
}

// Reference Code Tracking & Logging (Tender Management)
model ReferenceCode {
  id               String              @id @default(uuid())
  tenderId         String
  tender           Tender              @relation(fields: [tenderId], references: [id])
  oldReferenceCode String?
  newReferenceCode String?
  actionType       ReferenceCodeAction
  actionReason     String?
  actionBy         String?
  createdAt        DateTime            @default(now())

  @@map("reference_codes")
}

enum ReferenceCodeAction {
  GENERATED
  UPDATED
  DELETED
  REGENERATED
  MISSING
}

// ============================================================
// TECHNICAL CLARIFICATION MODULE
// ============================================================

model ReferenceCodeCounter {
  id           String   @id @default(uuid())
  companyId    String
  company      Company  @relation(fields: [companyId], references: [id])
  prefix       String   @default("REF")
  lastSequence Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([companyId, prefix])
  @@map("reference_code_counters")
}

// ============================================================
// TECHNICAL CLARIFICATION MODULE
// ============================================================

model TechnicalClarification {
  id String @id @default(uuid())

  companyId String
  tenderId  String

  question String

  raisedById   String
  assignedToId String?

  dueDate DateTime?

  priority TechnicalClarificationPriority @default(MEDIUM)
  status   TechnicalClarificationStatus   @default(OPEN)
  revision Int                            @default(1)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  company Company @relation(fields: [companyId], references: [id])
  tender  Tender  @relation(fields: [tenderId], references: [id])

  raisedBy User @relation("TechnicalClarificationRaisedBy", fields: [raisedById], references: [id])

  assignedTo User? @relation("TechnicalClarificationAssignedTo", fields: [assignedToId], references: [id])

  replies     TechnicalClarificationReply[]
  attachments TechnicalClarificationAttachment[]
  activities  TechnicalClarificationActivity[]

  @@index([companyId])
  @@index([tenderId])
  @@index([status])
  @@index([priority])
  @@map("technical_clarifications")
}

enum TechnicalClarificationStatus {
  OPEN
  ANSWERED
  REVISED
  CLOSED
}

enum TechnicalClarificationPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model TechnicalClarificationReply {
  id              String   @id @default(uuid())
  clarificationId String
  reply           String
  repliedById     String
  isInternal      Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  clarification TechnicalClarification @relation(fields: [clarificationId], references: [id])
  repliedBy     User                   @relation(fields: [repliedById], references: [id])

  @@index([clarificationId])
  @@map("technical_clarification_replies")
}

model TechnicalClarificationAttachment {
  id              String   @id @default(uuid())
  clarificationId String
  fileName        String
  fileUrl         String
  fileSize        Int?
  mimeType        String?
  uploadedById    String
  createdAt       DateTime @default(now())

  clarification TechnicalClarification @relation(fields: [clarificationId], references: [id])
  uploadedBy    User                   @relation(fields: [uploadedById], references: [id])

  @@index([clarificationId])
  @@map("technical_clarification_attachments")
}

model TechnicalClarificationActivity {
  id              String   @id @default(uuid())
  clarificationId String
  action          String
  oldValue        Json?
  newValue        Json?
  performedById   String?
  createdAt       DateTime @default(now())

  clarification TechnicalClarification @relation(fields: [clarificationId], references: [id])
  performedBy   User?                  @relation(fields: [performedById], references: [id])

  @@index([clarificationId])
  @@map("technical_clarification_activities")
}

// ============================================================
// BOQ / RFQ ANALYSIS MODULE
// ============================================================

model BOQ {
  id           String    @id @default(uuid())
  companyId    String
  tenderId     String
  version      Int       @default(1)
  isActive     Boolean   @default(true)
  importedFrom String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  company Company @relation(fields: [companyId], references: [id])
  tender  Tender  @relation(fields: [tenderId], references: [id])

  items       BOQItem[]
  attachments BOQAttachment[]

  @@unique([tenderId, version])
  @@index([companyId])
  @@map("boqs")
}

model BOQItem {
  id              String    @id @default(uuid())
  boqId           String
  itemCode        String
  description     String
  specification   String?
  unit            String
  quantity        Decimal   @db.Decimal(15, 3)
  brand           String?
  make            String?
  preferredVendor String?
  remarks         String?
  estimatedCost   Decimal?  @db.Decimal(15, 2)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  boq BOQ @relation(fields: [boqId], references: [id])

  @@index([boqId])
  @@index([itemCode])
  @@map("boq_items")
}

model BOQAttachment {
  id           String   @id @default(uuid())
  boqId        String
  fileName     String
  fileUrl      String
  fileSize     Int?
  mimeType     String?
  uploadedById String
  createdAt    DateTime @default(now())

  boq        BOQ  @relation(fields: [boqId], references: [id])
  uploadedBy User @relation(fields: [uploadedById], references: [id])

  @@index([boqId])
  @@map("boq_attachments")
}

// ============================================================
// 3. QUOTATION MANAGEMENT MODULE
// ============================================================

model Quotation {
  id             String          @id @default(uuid())
  companyId      String
  quotationNo    String          @unique
  tenderId       String?
  customerId     String
  revision       Int             @default(1)
  status         QuotationStatus @default(DRAFT)
  materialCost   Decimal         @db.Decimal(15, 2)
  labourCost     Decimal         @default(0) @db.Decimal(15, 2)
  transportation Decimal         @default(0) @db.Decimal(15, 2)
  packing        Decimal         @default(0) @db.Decimal(15, 2)
  insurance      Decimal         @default(0) @db.Decimal(15, 2)
  discount       Decimal         @default(0) @db.Decimal(15, 2)
  gst            Decimal         @db.Decimal(5, 2)
  profitMargin   Decimal         @db.Decimal(5, 2)
  finalAmount    Decimal         @db.Decimal(15, 2)
  currency       String          @default("INR")
  validUntil     DateTime
  remarks        String?

  createdById  String
  approvedById String?

  approvedAt      DateTime?
  sentAt          DateTime?
  acceptedAt      DateTime?
  rejectedAt      DateTime?
  rejectionReason String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  company  Company  @relation(fields: [companyId], references: [id])
  tender   Tender?  @relation(fields: [tenderId], references: [id])
  customer Customer @relation(fields: [customerId], references: [id])

  createdBy User @relation("QuotationCreatedBy", fields: [createdById], references: [id])

  approvedBy User? @relation("QuotationApprovedBy", fields: [approvedById], references: [id])

  revisions   QuotationRevision[]
  items       QuotationItem[]
  charges     QuotationCharge[]
  attachments QuotationAttachment[]
  salesOrders SalesOrder[]

  @@index([companyId])
  @@index([status])
  @@index([validUntil])
  @@map("quotations")
}

enum QuotationStatus {
  DRAFT
  WAITING_APPROVAL
  APPROVED
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
}

model QuotationRevision {
  id          String   @id @default(uuid())
  quotationId String
  revisionNo  Int
  changes     Json?
  reason      String?
  revisedById String
  createdAt   DateTime @default(now())

  quotation Quotation @relation(fields: [quotationId], references: [id])
  revisedBy User      @relation(fields: [revisedById], references: [id])

  @@unique([quotationId, revisionNo])
  @@index([quotationId])
  @@map("quotation_revisions")
}

model QuotationItem {
  id            String    @id @default(uuid())
  quotationId   String
  itemCode      String
  description   String
  specification String?
  unit          String
  quantity      Decimal   @db.Decimal(15, 3)
  unitPrice     Decimal   @db.Decimal(15, 2)
  totalPrice    Decimal   @db.Decimal(15, 2)
  brand         String?
  make          String?
  remarks       String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  quotation Quotation @relation(fields: [quotationId], references: [id])

  @@index([quotationId])
  @@map("quotation_items")
}

model QuotationCharge {
  id           String   @id @default(uuid())
  quotationId  String
  chargeType   String
  description  String?
  amount       Decimal  @db.Decimal(15, 2)
  isPercentage Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  quotation Quotation @relation(fields: [quotationId], references: [id])

  @@index([quotationId])
  @@map("quotation_charges")
}

model QuotationAttachment {
  id           String   @id @default(uuid())
  quotationId  String
  fileName     String
  fileUrl      String
  fileSize     Int?
  mimeType     String?
  uploadedById String
  createdAt    DateTime @default(now())

  quotation  Quotation @relation(fields: [quotationId], references: [id])
  uploadedBy User      @relation(fields: [uploadedById], references: [id])

  @@index([quotationId])
  @@map("quotation_attachments")
}

// ============================================================
// 4. QUOTATION APPROVAL ENGINE
// ============================================================

model ApprovalWorkflow {
  id          String    @id @default(uuid())
  companyId   String
  name        String
  description String?
  module      String // QUOTATION, PURCHASE, etc
  isActive    Boolean   @default(true)
  isSystem    Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  company Company @relation(fields: [companyId], references: [id])

  levels   ApprovalLevel[]
  requests ApprovalRequest[]

  @@unique([companyId, name])
  @@index([companyId])
  @@map("approval_workflows")
}

model ApprovalLevel {
  id              String       @id @default(uuid())
  workflowId      String
  levelNo         Int
  name            String
  approverRoleId  String
  minAmount       Decimal?     @db.Decimal(15, 2)
  maxAmount       Decimal?     @db.Decimal(15, 2)
  escalationHours Int?
  approvalType    ApprovalType @default(SEQUENTIAL)
  isParallel      Boolean      @default(false)
  isFinal         Boolean      @default(false)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  deletedAt       DateTime?

  workflow     ApprovalWorkflow @relation(fields: [workflowId], references: [id])
  approverRole Role             @relation(fields: [approverRoleId], references: [id])

  requests          ApprovalRequest[]
  approvalHistories ApprovalHistory[]

  @@unique([workflowId, levelNo])
  @@index([workflowId])
  @@map("approval_levels")
}

enum ApprovalType {
  SEQUENTIAL
  PARALLEL
  ANY
}

model ApprovalRequest {
  id         String         @id @default(uuid())
  companyId  String
  workflowId String
  levelId    String
  recordId   String
  recordType String
  status     ApprovalStatus @default(PENDING)

  requestedById String
  assignedToId  String?

  dueDate     DateTime?
  escalatedAt DateTime?
  remarks     String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  company  Company          @relation(fields: [companyId], references: [id])
  workflow ApprovalWorkflow @relation(fields: [workflowId], references: [id])
  level    ApprovalLevel    @relation(fields: [levelId], references: [id])

  requestedBy User @relation("ApprovalRequestRequestedBy", fields: [requestedById], references: [id])

  assignedTo User? @relation("ApprovalRequestAssignedTo", fields: [assignedToId], references: [id])

  history ApprovalHistory[]

  @@index([companyId])
  @@index([recordId])
  @@index([status])
  @@map("approval_requests")
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  ESCALATED
  REASSIGNED
  CANCELLED
}

model ApprovalHistory {
  id                   String         @id @default(uuid())
  requestId            String
  levelId              String
  action               ApprovalAction
  comments             String?
  performedById        String
  previousAssignedToId String?
  createdAt            DateTime       @default(now())

  request     ApprovalRequest @relation(fields: [requestId], references: [id])
  level       ApprovalLevel   @relation(fields: [levelId], references: [id])
  performedBy User            @relation(fields: [performedById], references: [id])

  @@index([requestId])
  @@map("approval_history")
}

enum ApprovalAction {
  APPROVED
  REJECTED
  REASSIGNED
  ESCALATED
  COMMENTED
}

